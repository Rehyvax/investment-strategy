# Template for dashboard/.streamlit/secrets.toml.
# DO NOT commit the actual secrets.toml. Copy this file to
# `.streamlit/secrets.toml` and replace the placeholders with real
# tokens. For Streamlit Cloud, paste the same TOML into the app's
# Secrets panel (Advanced settings → Secrets).
#
# Auth model: any caller hitting the dashboard URL with
# `?token=<one of valid_tokens>` is admitted. Rotate by editing this
# file and restarting the app.

[auth]
valid_tokens = ["REPLACE_WITH_PRIMARY_TOKEN", "REPLACE_WITH_SECONDARY_TOKEN"]

# Anthropic API key. Required to enable LLM narratives (Bloque A
# market, Bloque E comparative) and the Mercado-AI conversational
# surface in Pantalla 6. If absent, those surfaces fall back to the
# deterministic generator and Mercado-AI shows an inline warning.
#
# Streamlit Cloud: paste EITHER form in Advanced settings → Secrets.
# Both are bridged to os.environ["ANTHROPIC_API_KEY"] by
# dashboard/auth.py at import time, before any downstream module
# reads the env var.
#
# Form 1 (flat, recommended for Cloud):
#   ANTHROPIC_API_KEY = "sk-ant-..."
#
# Form 2 (nested, kept for backwards compatibility):
[anthropic]
api_key = ""
