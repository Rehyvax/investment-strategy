# =============================================================================
# Investment Strategy Lab — environment variables
# =============================================================================
# Copy this file to `.env` (which is git-ignored) and fill in your keys.
# Never commit `.env`. Never paste real keys into chat with Claude.
#
# All keys are read by `pydantic-settings` from this file at startup. Missing
# REQUIRED keys cause the bootstrap check (§15 of CLAUDE.md) to fail loudly.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — macro data
# -----------------------------------------------------------------------------
# FRED (Federal Reserve Economic Data). Used by `macro-regime` agent for:
#   - Treasury yields & curve slope (DGS10, DGS2)
#   - Credit spreads (BAMLH0A0HYM2, BAMLC0A4CBBB)
#   - VIX proxy (VIXCLS), unemployment, inflation expectations
# Free tier, generous limits. Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=


# -----------------------------------------------------------------------------
# OPTIONAL — fundamentals & news (fallbacks to yfinance / SEC EDGAR if absent)
# -----------------------------------------------------------------------------
# Financial Modeling Prep — broad fundamentals for non-US issuers (EU, UK).
# Free tier = 250 req/day. Used by `fundamental-analyst` for income statements,
# Piotroski F-score components, balance-sheet history.
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Finnhub — earnings calendar, analyst estimates, insider transactions.
# Free tier = 60 req/min. Used by `news-scanner` and earnings catalysts.
# https://finnhub.io/dashboard
FINNHUB_API_KEY=

# MarketAux — news aggregator with per-ticker sentiment tagging.
# Free tier = 100 req/day. Used by `news-scanner` for multi-source coverage
# of company-specific events; multi-ticker per query supported.
# https://www.marketaux.com
MARKETAUX_API_KEY=

# NewsAPI — general news coverage (macro, market, sector).
# Free tier = 100 req/day. Used by `news-scanner` as broader fallback;
# weaker ticker mapping but useful for sector-level events.
# https://newsapi.org
NEWSAPI_KEY=

# Alpha Vantage — long-history daily prices fallback when yfinance throttles.
# Free tier = 25 req/day. Last-resort source only.
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=


# -----------------------------------------------------------------------------
# OPTIONAL — SEC EDGAR contact
# -----------------------------------------------------------------------------
# SEC requires a contact email in the User-Agent header for programmatic access.
# Format: "AppName contact@example.com". Used when pulling 10-K / 10-Q filings.
SEC_EDGAR_USER_AGENT="investment-strategy-lab contact@example.com"


# -----------------------------------------------------------------------------
# OPTIONAL — OpenBB Platform (extra data aggregator)
# -----------------------------------------------------------------------------
# Personal Access Token from https://my.openbb.co/. Only needed if you install
# the `extra` optional dependency group and want OpenBB-managed providers.
OPENBB_PAT=


# -----------------------------------------------------------------------------
# OPTIONAL — Notifications (used by scripts/notifications.py)
# -----------------------------------------------------------------------------
# Email is sent via SMTP STARTTLS. For Gmail use an "App password"
# generated at https://myaccount.google.com/apppasswords (your normal
# Google password is NOT accepted on SMTP). Outlook / corporate SMTP
# work too — adjust SMTP_HOST and SMTP_PORT.
# When SMTP_USER/SMTP_PASS are blank the email path is silently skipped.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Telegram bot (optional second channel). Both keys must be set or the
# Telegram path is silently skipped.
# - Create bot via @BotFather (returns the token)
# - Get your chat_id by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# -----------------------------------------------------------------------------
# System behavior toggles
# -----------------------------------------------------------------------------
# Logging verbosity for src/ modules. One of: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Path overrides (rarely needed — defaults follow §3 of CLAUDE.md).
# DATA_DIR=./data
# CACHE_DB_PATH=./data/cache.duckdb
